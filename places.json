:root{--bg:#071715;--card:#102622;--text:#f2fff7;--muted:#a7b8ae;--green:#72c050;--blue:#1199d5;--yellow:#e7d34b}*{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,Segoe UI,sans-serif;background:linear-gradient(180deg,#08231f,#071715);color:var(--text)}header{display:flex;gap:14px;align-items:center;padding:22px;background:linear-gradient(135deg,#063a33,#0b765d);border-radius:0 0 28px 28px}h1{margin:0;font-size:30px}p{line-height:1.35}.icon{width:64px;height:64px;border-radius:18px;background:#0b2a2a;display:grid;place-items:center;font-size:34px;box-shadow:0 8px 25px #0005}.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:16px}.stats div{background:var(--card);border:1px solid #ffffff18;border-radius:18px;padding:14px}.stats b{display:block;font-size:24px}.stats span{color:var(--muted);font-size:13px}main{padding-bottom:40px}input{display:block;width:calc(100% - 32px);margin:12px 16px;padding:14px;border:0;border-radius:16px;background:#fff;color:#111;font-size:16px}nav{display:flex;gap:8px;overflow:auto;padding:0 16px 14px}button{border:0;border-radius:999px;padding:10px 14px;background:#183832;color:var(--text);white-space:nowrap}button.active{background:var(--green);color:#05210d;font-weight:700}#cards{display:grid;gap:14px;padding:0 16px}.card{background:linear-gradient(180deg,#12302b,#0d221f);border:1px solid #ffffff14;border-radius:22px;overflow:hidden;box-shadow:0 10px 30px #0003}.hero{height:118px;background:linear-gradient(135deg,#6abf69,#7cc7dc 65%,#e9d85c);display:flex;align-items:flex-end;padding:14px;font-size:22px;font-weight:800;text-shadow:0 2px 8px #0009}.body{padding:14px}.badge{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 10px;font-size:13px;font-weight:700;margin:2px 4px 8px 0}.visited{background:#72c050;color:#05210d}.pending{background:#1199d5;color:white}.cat{background:#ffffff18;color:white}.muted{color:var(--muted)}.tip{background:#061b18;border-left:4px solid var(--yellow);padding:10px;border-radius:12px}.actions a{display:inline-block;margin-top:8px;background:#0c8f70;color:white;text-decoration:none;border-radius:999px;padding:10px 12px;font-weight:700}
